# ── Backend URL (set this once backend is deployed) ───────────────────────────
# When set, ALL API calls route through the backend. No other keys needed.
# VITE_API_URL=https://job-tailor-api.azurewebsites.net/api

# ── Direct API keys (only needed WITHOUT a backend / local dev) ───────────────
VITE_ANTHROPIC_API_KEY=your_anthropic_key_here
VITE_ADZUNA_APP_ID=your_adzuna_app_id
VITE_ADZUNA_APP_KEY=your_adzuna_app_key
VITE_MUSE_API_KEY=your_muse_api_key
VITE_USAJOBS_API_KEY=your_usajobs_api_key
VITE_USAJOBS_USER_AGENT=your_email@example.com
